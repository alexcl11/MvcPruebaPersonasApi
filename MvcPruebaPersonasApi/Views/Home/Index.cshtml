@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Api Personas Client</h1>
    <button class="btn btn-primary" id="botonpersonas">
        Load Personas
    </button>
    <table class="table table-bordered" id="tablapersonas">
        <thead>
            <th>Id</th>
            <th>Nombre</th>
            <th>Email</th>
            <th>Edad</th>
        </thead>
        <tbody></tbody>
    </table>
</div>

@section Scripts{
    <script>
        $(document).ready(function(){
            $("#botonpersonas").click(function(){
                let url = "https://apipersonasacl-bza0fac2cjbtbua7.italynorth-01.azurewebsites.net/";
                let request = "api/personas";
                $.ajax({
                    url: url+request,
                    method: "GET",
                    success: function(data){                        
                        var html = "";
                        $.each(data, function(index, persona){
                            html += "<tr>";
                            html += "<td>" + persona.idPersona + "</td>";
                            html += "<td>" + persona.nombre + "</td>";
                            html += "<td>" + persona.email + "</td>";
                            html += "<td>" + persona.edad + "</td>";
                            html += "</tr>";
                        })
                        $("#tablapersonas tbody").html(html);
                    }
                })
            })
        })
    </script>
}